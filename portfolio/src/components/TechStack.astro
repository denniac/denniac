---
const technologies = [
  'Go',
  'Spring Boot',
  'Angular',
  'Astro',
  'PostgreSQL',
  'Docker',
  'Kubernetes',
  'Cloudflare',
  'Java',
  'TypeScript',
  'Python',
  'AWS',
];
---

<section id="stack" class="mx-auto max-w-7xl px-6 mt-32">
  <div class="mb-10">
    <p class="mb-3 text-sm uppercase tracking-[0.3em] text-[#29BE43]">
      Tech Stack
    </p>
    <h2 class="text-3xl font-bold text-white md:text-4xl">
      Technologies I work with
    </h2>
  </div>

  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    {technologies.map((tech) => (
      <div class="rounded-2xl border border-white/10 bg-white/5 p-5 text-center text-sm font-medium text-gray-300 backdrop-blur transition hover:border-[#29BE43]/40 hover:bg-white/10 hover:text-white">
        {tech}
      </div>
    ))}
  </div>
</section>
